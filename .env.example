# ─── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (Supabase Postgres + pgvector) ─────────────────────────────
# Use the "Transaction" pooler URL from Supabase for app runtime.
# pgvector extension must be enabled: `CREATE EXTENSION IF NOT EXISTS vector;`
DATABASE_URL=postgresql://user:pass@host:5432/postgres

# ─── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL_RERANK=gpt-4.1
OPENAI_MODEL_CHAT=gpt-4.1
OPENAI_MODEL_EMBED=text-embedding-3-small

# ─── LLM provider selection (openai | gemini) ────────────────────────────
LLM_PROVIDER=openai

# ─── WATI ────────────────────────────────────────────────────────────────
# From WATI dashboard → API Docs
WATI_API_BASE_URL=https://live-server-XXXXX.wati.io
WATI_API_TOKEN=REPLACE_ME
# Shared secret you also paste into the WATI webhook settings as X-Webhook-Secret
WATI_WEBHOOK_SECRET=generate-a-long-random-string
# Optional approved template used ONLY to reopen a session after the 24h window
WATI_REOPEN_TEMPLATE=cofounder_reopen_v1

# ─── Admin ───────────────────────────────────────────────────────────────
# Bearer token required for /admin/* routes
ADMIN_TOKEN=generate-a-long-random-string

# ─── Consent ─────────────────────────────────────────────────────────────
CONSENT_EXPIRY_HOURS=72
