# Build3 Cofounder Bot — env template
#
# IMPORTANT — secrets are loaded from macOS Keychain at runtime, not from .env.
# See ADR-008 in docs/DECISIONS.md.
#
# Local dev:
#   source ./scripts/load-env-from-keychain.sh
#   npm run dev
#
# CI / Vercel prod: env vars are set in the platform dashboard — see
# docs/DEPLOY.md. Never commit a populated .env to the repo.
#
# The keys listed below are the *contract* the server expects at boot
# (validated by src/lib/config.ts via Zod). Non-secret defaults are safe to
# leave here; secret values are sourced from Keychain or the Vercel dashboard.

# ─── Server (non-secret) ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (Supabase Postgres + pgvector) ─────────────────────────────
# Use the "Transaction" pooler URL from Supabase → Settings → Database.
# pgvector must be enabled: `CREATE EXTENSION IF NOT EXISTS vector;`
# SECRET — set via Keychain: build3-cofounder-bot/DATABASE_URL
DATABASE_URL=__keychain:build3-cofounder-bot/DATABASE_URL

# ─── OpenAI ──────────────────────────────────────────────────────────────
# Optional when LLM_PROVIDER=openai
# SECRET — set via Keychain: build3-cofounder-bot/OPENAI_API_KEY
OPENAI_API_KEY=__keychain:build3-cofounder-bot/OPENAI_API_KEY
OPENAI_MODEL_RERANK=gpt-4.1
OPENAI_MODEL_CHAT=gpt-4.1
OPENAI_MODEL_EMBED=text-embedding-3-small

# ─── Gemini ──────────────────────────────────────────────────────────────
# SECRET — set via Keychain: build3-cofounder-bot/GOOGLE_AI_KEY
GOOGLE_AI_KEY=__keychain:build3-cofounder-bot/GOOGLE_AI_KEY
GEMINI_MODEL_CHAT=gemini-2.5-flash
GEMINI_MODEL_EMBED=gemini-embedding-001

# ─── LLM provider selection (openai | gemini) ────────────────────────────
LLM_PROVIDER=gemini

# ─── WATI ────────────────────────────────────────────────────────────────
# SECRETs — set via Keychain: build3-cofounder-bot/WATI_API_URL (alias), WATI_API_TOKEN, WATI_WEBHOOK_SECRET
WATI_API_BASE_URL=__keychain:build3-cofounder-bot/WATI_API_URL
WATI_API_TOKEN=__keychain:build3-cofounder-bot/WATI_API_TOKEN
WATI_WEBHOOK_SECRET=__keychain:build3-cofounder-bot/WATI_WEBHOOK_SECRET
WATI_REOPEN_TEMPLATE=cofounder_reopen_v1

# ─── Admin ───────────────────────────────────────────────────────────────
# SECRET — set via Keychain: build3-cofounder-bot/ADMIN_TOKEN (auto-generated on setup)
ADMIN_TOKEN=__keychain:build3-cofounder-bot/ADMIN_TOKEN

# ─── Consent ─────────────────────────────────────────────────────────────
CONSENT_EXPIRY_HOURS=72
